# Production: replace YOUR_DOMAIN with your actual domain.
# Caddy auto-provisions TLS when a real domain is used.
#
# Development: use :80 instead of the domain block for plain HTTP.
#   :80 {
#       ...
#   }

{$CADDY_DOMAIN::80} {
	# WebSocket upgrade for /ws/*
	@ws {
		path /ws/*
		header Connection *Upgrade*
		header Upgrade    websocket
	}
	reverse_proxy @ws api-gateway:3000

	# Everything else → API gateway
	reverse_proxy api-gateway:3000
}
