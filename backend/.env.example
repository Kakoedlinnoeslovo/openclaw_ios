# ── Secrets (generate with: openssl rand -hex 32) ──
DB_PASSWORD=changeme_db_password
JWT_SECRET=changeme_jwt_secret
OPENCLAW_GATEWAY_TOKEN=changeme_gateway_token

# ── LLM Provider Keys ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Environment ──
NODE_ENV=development

# ── Domain (production only, used by Caddyfile) ──
# DOMAIN=api.your-openclaw-server.com
